{
  "name": "crypto-pigeon",
  "private": true,
  "version": "0.1.0",
  "description": "Privacy-first E2EE chat MVP",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:relay": "npm run dev --workspace=@crypto-pigeon/relay-server",
    "dev:daemon": "npm run dev --workspace=@crypto-pigeon/local-daemon",
    "dev:ui": "npm run dev --workspace=@crypto-pigeon/local-ui",
    "admin": "npm run start --workspace=@crypto-pigeon/admin-cli --",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test --workspace=@crypto-pigeon/tests",
    "typecheck": "npm run build --workspaces",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset-dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/reset-dev.ps1",
    "verify": "npm run build && npm run test && git diff --check"
  },
  "engines": { "node": ">=22" }
}
